<% content_for(:title) { "Billing - SupportPages" } %>

<%# Checkmark icon helper %>
<% check_icon = capture do %>
  <div class="w-5 h-5 bg-emerald-500/15 rounded flex items-center justify-center flex-shrink-0 mt-0.5">
    <svg class="w-3 h-3 text-emerald-500 dark:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
  </div>
<% end %>

<div class="app-bg min-h-screen">
  <%= render "shared/app_header" %>

  <main class="max-w-4xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold app-text" style="font-family: var(--app-font-display);">Billing</h1>
      <p class="mt-1 text-sm app-text-secondary">Manage your plan and subscription.</p>
    </div>

    <% if @user.plan_past_due? %>
      <div class="bg-red-500/10 border border-red-500/30 rounded-lg p-4 mb-6 flex items-start gap-3">
        <svg class="w-5 h-5 text-red-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <div>
          <p class="text-sm font-medium text-red-400">Payment past due</p>
          <p class="text-sm text-red-400/80 mt-1">Please update your payment method to keep your Pro features active.</p>
        </div>
      </div>
    <% end %>

    <% if @user.on_trial? %>
      <div class="bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/20 rounded-lg p-4 mb-6 flex items-start gap-3">
        <svg class="w-5 h-5 text-blue-500 dark:text-blue-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-sm text-blue-700 dark:text-blue-400">
          Trial active &mdash; <strong><%= @user.trial_days_remaining %> days remaining</strong>. Add a payment method to keep Pro features after your trial ends.
        </p>
      </div>
    <% end %>

    <%
      upgrade_message = flash[:alert].presence || {
        "custom_branding" => "Custom branding (logo, colors) requires a Pro plan. Upgrade to match your brand.",
        "custom_domain" => "Custom domains require a Pro plan. Upgrade to use your own domain."
      }[params[:reason]]
    %>
    <% if upgrade_message.present? %>
      <div class="bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/20 rounded-lg p-4 mb-6 flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-500 dark:text-amber-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
        <p class="text-sm text-amber-700 dark:text-amber-400"><%= upgrade_message %></p>
      </div>
    <% end %>

    <!-- Plan Cards -->
    <div data-controller="billing-toggle">
      <% if @user.free? %>
        <div class="flex justify-center mb-6">
          <div class="inline-flex items-center app-surface-alt rounded-full p-1 border app-border">
            <button data-billing-toggle-target="monthlyBtn"
                    data-action="click->billing-toggle#selectMonthly"
                    class="px-4 py-1.5 text-sm font-medium rounded-full transition-all duration-200 app-text-muted">
              Monthly
            </button>
            <button data-billing-toggle-target="annualBtn"
                    data-action="click->billing-toggle#selectAnnual"
                    class="px-4 py-1.5 text-sm font-medium rounded-full transition-all duration-200 bg-white dark:bg-zinc-700 app-text shadow-sm">
              Annual <span class="text-emerald-600 dark:text-emerald-400 font-semibold">save 23%</span>
            </button>
          </div>
        </div>
      <% end %>

      <div class="grid md:grid-cols-3 gap-5 mb-8">

        <!-- Free -->
        <div class="app-surface rounded-xl border <%= @user.free? ? 'ring-2 ring-[color:var(--app-accent)]' : 'app-border' %> p-5 flex flex-col">
          <%# Row 1: Title — fixed height %>
          <div class="h-7 flex items-center justify-between mb-2">
            <h3 class="text-base font-semibold app-text">Free</h3>
            <% if @user.free? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-500/15 text-emerald-600 dark:text-emerald-400">Current plan</span>
            <% end %>
          </div>
          <%# Row 2: Description — fixed height %>
          <p class="text-sm app-text-secondary h-10 mb-3">For open source & hobby projects</p>
          <%# Row 3: Price — fixed height %>
          <div class="flex items-baseline gap-1 h-10 mb-4">
            <span class="text-3xl font-bold app-text" style="font-family: var(--app-font-display);">$0</span>
            <span class="app-text-muted text-sm">/month</span>
          </div>

          <ul class="space-y-2.5 mb-6 flex-1">
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">1 project</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">10 articles</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Subdomain help centre</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">100 AI answers/month</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">1 team member</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">SupportPages badge</span></li>
          </ul>

          <div class="text-center text-sm font-medium app-text-muted py-2.5 border app-border rounded-lg">
            <% if @user.free? %>Your current plan<% else %>Free plan<% end %>
          </div>
        </div>

        <!-- Pro -->
        <div class="app-surface rounded-xl border <%= @user.pro? ? 'ring-2 ring-[color:var(--app-accent)]' : 'border-zinc-300 dark:border-zinc-600' %> p-5 flex flex-col relative">
          <% unless @user.pro? %>
            <div class="absolute -top-2.5 left-1/2 -translate-x-1/2">
              <span class="px-2.5 py-0.5 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 text-xs font-semibold rounded-full whitespace-nowrap">Most popular</span>
            </div>
          <% end %>

          <%# Row 1: Title — fixed height %>
          <div class="h-7 flex items-center justify-between mb-2">
            <h3 class="text-base font-semibold app-text">Pro</h3>
            <% if @user.pro? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-500/15 text-emerald-600 dark:text-emerald-400">Current plan</span>
            <% end %>
          </div>
          <%# Row 2: Description — fixed height %>
          <p class="text-sm app-text-secondary h-10 mb-3">For startups & growing teams</p>
          <%# Row 3: Price — fixed height %>
          <div data-billing-toggle-target="annual" class="flex items-baseline gap-1 h-10 mb-4">
            <span class="text-3xl font-bold app-text" style="font-family: var(--app-font-display);">$99</span>
            <span class="app-text-muted text-sm">/month</span>
          </div>
          <div data-billing-toggle-target="monthly" class="flex items-baseline gap-1 h-10 mb-4 hidden">
            <span class="text-3xl font-bold app-text" style="font-family: var(--app-font-display);">$129</span>
            <span class="app-text-muted text-sm">/month</span>
          </div>

          <ul class="space-y-2.5 mb-6 flex-1">
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Unlimited projects</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Unlimited articles</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Custom domain</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Unlimited AI answers</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Full custom branding</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Up to 10 team members</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Priority processing</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Analytics & notifications</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">No SupportPages badge</span></li>
          </ul>

          <% if @user.free? %>
            <p class="text-xs app-text-muted mb-2 text-center">14-day free trial. Cancel anytime.</p>
            <%= form_with url: checkout_billing_path, method: :post, data: { turbo: false } do |f| %>
              <input type="hidden" name="interval" value="annual" data-billing-toggle-target="intervalField">
              <%= f.submit "Start free trial", class: "btn-primary-md w-full cursor-pointer" %>
            <% end %>
          <% elsif @user.pro? %>
            <%= form_with url: portal_billing_path, method: :post, data: { turbo: false } do |f| %>
              <%= f.submit "Manage Subscription", class: "btn-primary-md w-full cursor-pointer" %>
            <% end %>
          <% end %>
        </div>

        <!-- Enterprise -->
        <div class="app-surface rounded-xl border <%= @user.enterprise? ? 'ring-2 ring-[color:var(--app-accent)]' : 'app-border' %> p-5 flex flex-col">
          <%# Row 1: Title — fixed height %>
          <div class="h-7 flex items-center justify-between mb-2">
            <h3 class="text-base font-semibold app-text">Enterprise</h3>
            <% if @user.enterprise? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-500/15 text-purple-600 dark:text-purple-400">Current plan</span>
            <% end %>
          </div>
          <%# Row 2: Description — fixed height %>
          <p class="text-sm app-text-secondary h-10 mb-3">For teams with strict security needs</p>
          <%# Row 3: Price — fixed height %>
          <div class="flex items-baseline gap-1 h-10 mb-4">
            <span class="text-3xl font-bold app-text" style="font-family: var(--app-font-display);">Custom</span>
          </div>

          <ul class="space-y-2.5 mb-6 flex-1">
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Everything in Pro</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Unlimited team members</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Self-hosted Docker container</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">SSO/SAML & audit log</span></li>
            <li class="flex items-start gap-2.5"><%= check_icon %><span class="text-sm app-text-secondary">Dedicated support & SLA</span></li>
          </ul>

          <a href="mailto:hello@supportpages.io" class="btn-secondary-md w-full text-center">Talk to us</a>
        </div>
      </div>
    </div>

    <!-- Usage -->
    <div class="app-surface rounded-lg app-shadow border app-border p-6">
      <h2 class="text-base font-semibold app-text mb-4">Usage</h2>
      <div class="grid grid-cols-3 gap-6">
        <div>
          <p class="text-xs font-medium app-text-muted uppercase tracking-wide mb-1">Projects</p>
          <p class="text-lg font-semibold app-text">
            <%= @project_count %>
            <span class="text-sm font-normal app-text-secondary">/ <%= @user.plan_limit(:projects) == Float::INFINITY ? "Unlimited" : @user.plan_limit(:projects) %></span>
          </p>
          <% if @user.free? && @project_count >= @user.plan_limit(:projects) %>
            <p class="text-xs text-amber-600 dark:text-amber-400 mt-1">Limit reached</p>
          <% end %>
        </div>
        <div>
          <p class="text-xs font-medium app-text-muted uppercase tracking-wide mb-1">Articles</p>
          <p class="text-lg font-semibold app-text">
            <%= @article_count %>
            <span class="text-sm font-normal app-text-secondary">/ <%= @user.plan_limit(:articles) == Float::INFINITY ? "Unlimited" : @user.plan_limit(:articles) %></span>
          </p>
          <% if @user.free? && @article_count >= @user.plan_limit(:articles) %>
            <p class="text-xs text-amber-600 dark:text-amber-400 mt-1">Limit reached</p>
          <% end %>
        </div>
        <div>
          <p class="text-xs font-medium app-text-muted uppercase tracking-wide mb-1">Team members</p>
          <p class="text-lg font-semibold app-text">
            <%= @team_member_count %>
            <span class="text-sm font-normal app-text-secondary">/ <%= @user.plan_limit(:team_members) == Float::INFINITY ? "Unlimited" : @user.plan_limit(:team_members) %></span>
          </p>
        </div>
      </div>
    </div>
  </main>
</div>
