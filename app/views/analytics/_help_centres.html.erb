<!-- Help Centres Summary -->
<div class="mt-6 grid grid-cols-3 gap-4">
  <div class="app-surface rounded-xl border app-border p-5">
    <p class="text-sm app-text-muted">Help Centres with Traffic</p>
    <p class="mt-1 text-3xl font-bold app-text"><%= @help_centres.size %></p>
  </div>
  <div class="app-surface rounded-xl border app-border p-5">
    <p class="text-sm app-text-muted">Total Page Views</p>
    <p class="mt-1 text-3xl font-bold app-text"><%= number_with_delimiter(@help_centres.sum { |h| h[:total_page_views] }) %></p>
  </div>
  <div class="app-surface rounded-xl border app-border p-5">
    <p class="text-sm app-text-muted">Total Unique Visitors</p>
    <p class="mt-1 text-3xl font-bold app-text"><%= number_with_delimiter(@help_centres.sum { |h| h[:unique_visitors] }) %></p>
  </div>
</div>

<!-- Help Centres Table -->
<% if @help_centres.any? %>
  <div class="mt-6 app-surface rounded-xl border border-zinc-200 dark:border-zinc-700/50 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full">
        <thead>
          <tr class="border-b app-border">
            <th class="px-4 py-3 text-left text-xs font-medium app-text-muted uppercase tracking-wider">Help Centre</th>
            <th class="px-4 py-3 text-left text-xs font-medium app-text-muted uppercase tracking-wider">Account</th>
            <th class="px-4 py-3 text-center text-xs font-medium app-text-muted uppercase tracking-wider">Page Views</th>
            <th class="px-4 py-3 text-center text-xs font-medium app-text-muted uppercase tracking-wider">Unique Visitors</th>
            <th class="px-4 py-3 text-center text-xs font-medium app-text-muted uppercase tracking-wider">Pages/Visitor</th>
            <th class="px-4 py-3 text-left text-xs font-medium app-text-muted uppercase tracking-wider">Top Page</th>
            <th class="px-4 py-3 text-center text-xs font-medium app-text-muted uppercase tracking-wider">Mobile %</th>
            <th class="px-4 py-3 text-center text-xs font-medium app-text-muted uppercase tracking-wider">Published</th>
            <th class="px-4 py-3 text-left text-xs font-medium app-text-muted uppercase tracking-wider">Domain</th>
          </tr>
        </thead>
        <tbody>
          <% @help_centres.each do |entry| %>
            <% project = entry[:project] %>
            <% user = entry[:user] %>
            <tr class="hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-colors cursor-pointer"
                onclick="window.location='<%= analytics_help_centre_path(project, period: @period) %>'">
              <td class="px-4 py-3">
                <div>
                  <p class="text-sm font-medium app-text"><%= project.name %></p>
                  <p class="text-xs app-text-muted"><%= project.slug %></p>
                </div>
              </td>
              <td class="px-4 py-3">
                <p class="text-sm app-text"><%= user&.name || user&.github_username || "Unknown" %></p>
                <p class="text-xs app-text-muted"><%= user&.email %></p>
              </td>
              <td class="px-4 py-3 text-center text-sm app-text">
                <%= number_with_delimiter(entry[:total_page_views]) %>
              </td>
              <td class="px-4 py-3 text-center text-sm app-text">
                <%= number_with_delimiter(entry[:unique_visitors]) %>
              </td>
              <td class="px-4 py-3 text-center text-sm app-text">
                <%= entry[:avg_pages_per_visitor] %>
              </td>
              <td class="px-4 py-3 text-xs app-text-muted truncate max-w-[200px]">
                <%= entry[:top_page] || "&mdash;".html_safe %>
              </td>
              <td class="px-4 py-3 text-center text-sm app-text">
                <%= entry[:mobile_pct] %>%
              </td>
              <td class="px-4 py-3 text-center text-sm app-text">
                <%= entry[:articles_published] %>
              </td>
              <td class="px-4 py-3 text-xs app-text-muted whitespace-nowrap">
                <%= entry[:custom_domain] || "&mdash;".html_safe %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="mt-6 app-surface rounded-xl border app-border p-12 text-center">
    <p class="text-sm app-text-muted">No help centre traffic recorded in this period</p>
    <p class="text-xs app-text-muted mt-1">Help centre page views will appear here once visitors start browsing</p>
  </div>
<% end %>
