<% content_for(:title) { "Visitor Details - Analytics - supportpages.io" } %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/app_header" %>

  <!-- Breadcrumb -->
  <div class="mt-6">
    <%= link_to "← Back to Visitors", analytics_path(tab: "visitors"), class: "text-sm app-text-muted hover:app-text transition-colors" %>
  </div>

  <!-- Header -->
  <div class="mt-4 flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold app-text" style="font-family: var(--app-font-display);">
        Visitor Details
      </h1>
      <p class="mt-1 text-xs font-mono app-text-muted"><%= @visitor.visitor_id %></p>
    </div>

    <% if @visitor.returning_visitor? %>
      <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">
        Returning Visitor
      </span>
    <% else %>
      <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">
        New Visitor
      </span>
    <% end %>
  </div>

  <!-- Summary Cards -->
  <div class="mt-6 grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="app-surface rounded-xl border app-border p-5">
      <p class="text-sm app-text-muted">Page Views</p>
      <p class="mt-1 text-3xl font-bold app-text"><%= number_with_delimiter(@visitor.total_page_views) %></p>
    </div>
    <div class="app-surface rounded-xl border app-border p-5">
      <p class="text-sm app-text-muted">Total Events</p>
      <p class="mt-1 text-3xl font-bold app-text"><%= number_with_delimiter(@visitor.total_events) %></p>
    </div>
    <div class="app-surface rounded-xl border app-border p-5">
      <p class="text-sm app-text-muted">First Seen</p>
      <p class="mt-1 text-xl font-semibold app-text"><%= @visitor.first_seen_at.strftime("%b %d, %Y") %></p>
      <p class="text-xs app-text-muted"><%= time_ago_in_words(@visitor.first_seen_at) %> ago</p>
    </div>
    <div class="app-surface rounded-xl border app-border p-5">
      <p class="text-sm app-text-muted">Last Seen</p>
      <p class="mt-1 text-xl font-semibold app-text"><%= @visitor.last_seen_at.strftime("%b %d, %Y") %></p>
      <p class="text-xs app-text-muted"><%= time_ago_in_words(@visitor.last_seen_at) %> ago</p>
    </div>
  </div>

  <!-- Identity & Attribution -->
  <div class="mt-6 grid lg:grid-cols-2 gap-6">
    <!-- Identity -->
    <div class="app-surface rounded-xl border app-border p-5">
      <h2 class="text-sm font-semibold app-text mb-4">Identity</h2>
      <% if @visitor.identified? %>
        <div class="space-y-3">
          <div>
            <p class="text-xs app-text-muted">Email</p>
            <p class="text-sm font-medium app-text"><%= @visitor.email %></p>
          </div>
          <% if @visitor.name.present? %>
            <div>
              <p class="text-xs app-text-muted">Name</p>
              <p class="text-sm font-medium app-text"><%= @visitor.name %></p>
            </div>
          <% end %>
          <% if @visitor.converted? %>
            <div>
              <p class="text-xs app-text-muted">Status</p>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400">
                Converted User (ID: <%= @visitor.user_id %>)
              </span>
            </div>
          <% else %>
            <div>
              <p class="text-xs app-text-muted">Status</p>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">
                Identified (Not Converted)
              </span>
            </div>
          <% end %>
          <div>
            <p class="text-xs app-text-muted">Identified At</p>
            <p class="text-sm app-text"><%= @visitor.identified_at.strftime("%b %d, %Y at %H:%M") %></p>
          </div>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-sm app-text-muted italic">Anonymous Visitor</p>
          <p class="text-xs app-text-muted mt-1">No identity information captured yet</p>
        </div>
      <% end %>
    </div>

    <!-- Attribution -->
    <div class="app-surface rounded-xl border app-border p-5">
      <h2 class="text-sm font-semibold app-text mb-4">Attribution (First Touch)</h2>
      <% if @visitor.utm_source.present? || @visitor.initial_referrer_url.present? %>
        <div class="space-y-3">
          <% if @visitor.utm_source.present? %>
            <div>
              <p class="text-xs app-text-muted">UTM Source</p>
              <p class="text-sm font-medium app-text"><%= @visitor.utm_source %></p>
            </div>
          <% end %>
          <% if @visitor.utm_medium.present? %>
            <div>
              <p class="text-xs app-text-muted">UTM Medium</p>
              <p class="text-sm app-text"><%= @visitor.utm_medium %></p>
            </div>
          <% end %>
          <% if @visitor.utm_campaign.present? %>
            <div>
              <p class="text-xs app-text-muted">UTM Campaign</p>
              <p class="text-sm app-text"><%= @visitor.utm_campaign %></p>
            </div>
          <% end %>
          <% if @visitor.utm_content.present? %>
            <div>
              <p class="text-xs app-text-muted">UTM Content</p>
              <p class="text-sm app-text"><%= @visitor.utm_content %></p>
            </div>
          <% end %>
          <% if @visitor.initial_referrer_url.present? %>
            <div>
              <p class="text-xs app-text-muted">Initial Referrer</p>
              <p class="text-sm app-text truncate" title="<%= @visitor.initial_referrer_url %>">
                <%= @visitor.initial_referrer_host %>
              </p>
            </div>
          <% end %>
          <% if @visitor.initial_landing_page.present? %>
            <div>
              <p class="text-xs app-text-muted">Landing Page</p>
              <p class="text-sm font-mono app-text"><%= @visitor.initial_landing_page %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-sm app-text-muted italic">Direct Traffic</p>
          <p class="text-xs app-text-muted mt-1">No UTM parameters or referrer captured</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Technical Details -->
  <div class="mt-6 app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">Technical Details</h2>
    <div class="grid lg:grid-cols-4 gap-6">
      <div>
        <p class="text-xs app-text-muted">Device Type</p>
        <p class="text-sm font-medium app-text capitalize"><%= @visitor.device_type || "Unknown" %></p>
      </div>
      <div>
        <p class="text-xs app-text-muted">Browser</p>
        <p class="text-sm font-medium app-text"><%= @visitor.browser_family || "Unknown" %></p>
      </div>
      <div>
        <p class="text-xs app-text-muted">Operating System</p>
        <p class="text-sm font-medium app-text"><%= @visitor.os_family || "Unknown" %></p>
      </div>
      <div>
        <p class="text-xs app-text-muted">Last IP Address</p>
        <p class="text-sm font-mono app-text"><%= @visitor.last_ip_address || "—" %></p>
      </div>
    </div>
  </div>

  <!-- Event Summary -->
  <div class="mt-6 app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">Event Summary</h2>
    <div class="flex flex-wrap gap-3">
      <% @event_summary.sort_by { |_, count| -count }.each do |event_type, count| %>
        <div class="app-surface-alt rounded-lg px-4 py-2 border app-border">
          <p class="text-xs app-text-muted"><%= event_type.humanize %></p>
          <p class="text-lg font-semibold app-text"><%= number_with_delimiter(count) %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent Activity -->
  <div class="mt-6 app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">Recent Activity (Last 100 Events)</h2>
    <% if @events.any? %>
      <div class="space-y-3">
        <% @events.each do |event| %>
          <div class="app-surface-alt rounded-lg p-3 border app-border">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= event.event_type == 'page_view' ? 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400' : event.event_type == 'video_play' ? 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400' : event.event_type == 'waitlist_submit' ? 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400' : 'bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-400' %>">
                    <%= event.event_type.humanize %>
                  </span>
                  <span class="text-sm font-mono app-text"><%= event.page_path %></span>
                </div>
                <% if event.event_data.present? && event.event_data.any? %>
                  <div class="mt-2 text-xs app-text-muted">
                    <% event.event_data.each do |key, value| %>
                      <span class="inline-block mr-3"><strong><%= key %>:</strong> <%= value %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <div class="flex flex-col items-end ml-4">
                <span class="text-xs app-text whitespace-nowrap"><%= event.created_at.strftime("%b %d, %Y") %></span>
                <span class="text-xs app-text-muted whitespace-nowrap"><%= event.created_at.strftime("%H:%M:%S") %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-sm app-text-muted">No events recorded yet</p>
      </div>
    <% end %>
  </div>
</div>
