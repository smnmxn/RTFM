<% content_for(:title) { "Analytics - supportpages.io" } %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%= render "shared/app_header" %>

  <div class="mt-6">
    <h1 class="text-2xl font-bold app-text" style="font-family: var(--app-font-display);">Analytics</h1>
    <p class="mt-1 text-sm app-text-muted"><%= { "product" => "Internal product usage", "projects" => "Per-project health and engagement", "visitors" => "Individual visitor tracking and journeys", "help_centres" => "Help centre visitor analytics" }.fetch(@tab, "Public page visitor engagement") %></p>
  </div>

  <!-- Tab switcher -->
  <div class="mt-4 flex gap-2">
    <% %w[public visitors product projects help_centres].each do |tab| %>
      <%= link_to tab.titleize,
          analytics_path(tab: tab, period: @period),
          class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors #{@tab == tab ? 'bg-zinc-900 text-white dark:bg-white dark:text-zinc-900' : 'app-text-muted hover:app-text app-surface-alt'}" %>
    <% end %>

    <div class="ml-auto flex gap-2">
      <% AnalyticsController::PERIODS.keys.each do |period| %>
        <%= link_to period,
            analytics_path(tab: @tab, period: period),
            class: "px-3 py-1.5 text-sm font-medium rounded-lg transition-colors #{@period == period ? 'bg-zinc-900 text-white dark:bg-white dark:text-zinc-900' : 'app-text-muted hover:app-text app-surface-alt'}" %>
      <% end %>
    </div>
  </div>

  <% if @tab == "visitors" %>
    <%= render "visitors" %>
  <% elsif @tab == "product" %>
    <%= render "product" %>
  <% elsif @tab == "projects" %>
    <%= render "projects" %>
  <% elsif @tab == "help_centres" %>
    <%= render "help_centres" %>
  <% else %>
    <%= render "public" %>
  <% end %>
</div>
