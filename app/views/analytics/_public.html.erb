<!-- Summary cards -->
<div class="mt-6 grid grid-cols-2 lg:grid-cols-4 gap-4">
  <div class="app-surface rounded-xl border app-border p-5">
    <p class="text-sm app-text-muted">Page Views</p>
    <p class="mt-1 text-3xl font-bold app-text"><%= number_with_delimiter(@data[:summary][:total_page_views]) %></p>
  </div>
  <div class="app-surface rounded-xl border app-border p-5">
    <p class="text-sm app-text-muted">Unique Visitors</p>
    <p class="mt-1 text-3xl font-bold app-text"><%= number_with_delimiter(@data[:summary][:unique_visitors]) %></p>
  </div>
  <div class="app-surface rounded-xl border app-border p-5">
    <p class="text-sm app-text-muted">Video Plays</p>
    <p class="mt-1 text-3xl font-bold app-text"><%= number_with_delimiter(@data[:engagement][:video_plays]) %></p>
  </div>
  <div class="app-surface rounded-xl border app-border p-5">
    <p class="text-sm app-text-muted">Signups</p>
    <p class="mt-1 text-3xl font-bold app-text"><%= number_with_delimiter(@data[:summary][:signups]) %></p>
    <p class="mt-0.5 text-xs app-text-muted"><%= @data[:summary][:signup_rate] %>% conversion</p>
  </div>
</div>

<!-- Visitor Breakdown -->
<% if @data[:visitor_breakdown] %>
  <div class="mt-6 app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">Visitor Insights</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <p class="text-xs app-text-muted">New Visitors</p>
        <p class="text-lg font-semibold app-text"><%= number_with_delimiter(@data[:visitor_breakdown][:new_visitors]) %></p>
      </div>
      <div>
        <p class="text-xs app-text-muted">Returning Visitors</p>
        <p class="text-lg font-semibold app-text"><%= number_with_delimiter(@data[:visitor_breakdown][:returning_visitors]) %></p>
      </div>
      <div>
        <p class="text-xs app-text-muted">Identified</p>
        <p class="text-lg font-semibold app-text"><%= number_with_delimiter(@data[:visitor_breakdown][:identified_visitors]) %></p>
      </div>
      <div>
        <p class="text-xs app-text-muted">Avg Pages/Visitor</p>
        <p class="text-lg font-semibold app-text"><%= @data[:visitor_breakdown][:avg_pages_per_visitor] %></p>
      </div>
    </div>
  </div>
<% end %>

<!-- Page views chart -->
<div class="mt-6 app-surface rounded-xl border app-border p-5">
  <h2 class="text-sm font-semibold app-text mb-4"><%= @period == "24h" ? "Hourly" : "Daily" %> Page Views</h2>
  <% if @data[:daily_views].any? %>
    <div style="height: 200px;">
      <canvas id="pageViewsChart"></canvas>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
      (function() {
        const isDark = document.documentElement.classList.contains('dark');
        const ctx = document.getElementById('pageViewsChart');

        const data = {
          labels: <%= raw @data[:daily_views].map { |d| d[:date] }.to_json %>,
          datasets: [
            {
              label: 'Views',
              data: <%= raw @data[:daily_views].map { |d| d[:views] }.to_json %>,
              borderColor: isDark ? 'rgb(161, 161, 170)' : 'rgb(63, 63, 70)',
              backgroundColor: isDark ? 'rgba(161, 161, 170, 0.1)' : 'rgba(63, 63, 70, 0.1)',
              tension: 0.4,
              fill: true
            },
            {
              label: 'Unique Visitors',
              data: <%= raw @data[:daily_views].map { |d| d[:uniques] }.to_json %>,
              borderColor: isDark ? 'rgb(212, 212, 216)' : 'rgb(113, 113, 122)',
              backgroundColor: isDark ? 'rgba(212, 212, 216, 0.1)' : 'rgba(113, 113, 122, 0.1)',
              tension: 0.4,
              fill: true
            }
          ]
        };

        new Chart(ctx, {
          type: 'line',
          data: data,
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: {
              mode: 'index',
              intersect: false,
            },
            plugins: {
              legend: {
                display: true,
                position: 'top',
                align: 'end',
                labels: {
                  color: isDark ? 'rgb(161, 161, 170)' : 'rgb(63, 63, 70)',
                  usePointStyle: true,
                  padding: 15,
                  font: {
                    size: 11
                  }
                }
              },
              tooltip: {
                backgroundColor: isDark ? 'rgb(39, 39, 42)' : 'rgb(255, 255, 255)',
                titleColor: isDark ? 'rgb(244, 244, 245)' : 'rgb(24, 24, 27)',
                bodyColor: isDark ? 'rgb(161, 161, 170)' : 'rgb(63, 63, 70)',
                borderColor: isDark ? 'rgb(63, 63, 70)' : 'rgb(228, 228, 231)',
                borderWidth: 1,
                padding: 12,
                displayColors: true,
                callbacks: {
                  label: function(context) {
                    return context.dataset.label + ': ' + context.parsed.y;
                  }
                }
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                ticks: {
                  color: isDark ? 'rgb(113, 113, 122)' : 'rgb(161, 161, 170)',
                  font: { size: 11 },
                  precision: 0
                },
                grid: {
                  color: isDark ? 'rgba(63, 63, 70, 0.3)' : 'rgba(228, 228, 231, 0.5)',
                  drawBorder: false
                }
              },
              x: {
                ticks: {
                  color: isDark ? 'rgb(113, 113, 122)' : 'rgb(161, 161, 170)',
                  font: { size: 11 },
                  maxRotation: 0,
                  autoSkip: true,
                  maxTicksLimit: <%= @period == "24h" ? 12 : 10 %>
                },
                grid: {
                  display: false,
                  drawBorder: false
                }
              }
            }
          }
        });
      })();
    </script>
  <% else %>
    <div class="flex items-center justify-center h-40 text-sm app-text-muted">
      No page view data for this period
    </div>
  <% end %>
</div>

<!-- Engagement section -->
<div class="mt-6 app-surface rounded-xl border app-border p-5">
  <h2 class="text-sm font-semibold app-text mb-4">Engagement</h2>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div>
      <p class="text-xs app-text-muted">Video Play Rate</p>
      <% play_rate = @data[:summary][:unique_visitors] > 0 ? (@data[:engagement][:video_plays].to_f / @data[:summary][:unique_visitors] * 100).round(1) : 0 %>
      <p class="text-lg font-semibold app-text"><%= play_rate %>%</p>
    </div>
    <div>
      <p class="text-xs app-text-muted">Avg Watch Progress</p>
      <p class="text-lg font-semibold app-text"><%= @data[:engagement][:avg_video_progress] %>%</p>
    </div>
    <div>
      <p class="text-xs app-text-muted">Signup Conversion</p>
      <p class="text-lg font-semibold app-text"><%= @data[:summary][:signup_rate] %>%</p>
    </div>
    <div>
      <p class="text-xs app-text-muted">CTA Clicks</p>
      <p class="text-lg font-semibold app-text"><%= number_with_delimiter(@data[:engagement][:cta_clicks]) %></p>
    </div>
  </div>

  <% if @data[:engagement][:cta_detail].any? %>
    <div class="mt-4 pt-4 border-t app-border">
      <p class="text-xs app-text-muted mb-2">CTA Breakdown</p>
      <div class="flex flex-wrap gap-2">
        <% @data[:engagement][:cta_detail].sort_by { |_, v| -v }.each do |cta, count| %>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium app-surface-alt app-text">
            <%= cta.to_s.humanize %> <span class="app-text-muted"><%= count %></span>
          </span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<!-- Funnel -->
<% if @data[:funnel][:steps].any? %>
  <div class="mt-6 app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">Conversion Funnel</h2>
    <div class="flex items-center gap-2">
      <% @data[:funnel][:steps].each_with_index do |step, i| %>
        <div class="flex-1 text-center">
          <p class="text-xs app-text-muted"><%= step[:name] %></p>
          <p class="text-lg font-semibold app-text"><%= number_with_delimiter(step[:count]) %></p>
        </div>
        <% if i < @data[:funnel][:steps].size - 1 %>
          <div class="text-xs app-text-muted flex flex-col items-center">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            <span><%= @data[:funnel][:rates][i][:rate] %>%</span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Two-column: Top Pages + Top Referrers -->
<div class="mt-6 grid lg:grid-cols-2 gap-6">
  <div class="app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">Top Pages</h2>
    <% if @data[:top_pages].any? %>
      <div class="space-y-2">
        <% @data[:top_pages].each do |page| %>
          <div class="flex justify-between items-center text-sm">
            <span class="app-text truncate mr-2"><%= page[:path] %></span>
            <span class="app-text-muted flex-shrink-0"><%= number_with_delimiter(page[:views]) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm app-text-muted">No data yet</p>
    <% end %>
  </div>

  <div class="app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">Top Referrers</h2>
    <% if @data[:top_referrers].any? %>
      <div class="space-y-2">
        <% @data[:top_referrers].each do |ref| %>
          <div class="flex justify-between items-center text-sm">
            <span class="app-text truncate mr-2"><%= ref[:host] %></span>
            <span class="app-text-muted flex-shrink-0"><%= number_with_delimiter(ref[:views]) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm app-text-muted">No referrer data yet</p>
    <% end %>
  </div>
</div>

<!-- Prospect Tracking (full width) -->
<% if @data[:prospect_tracking].any? %>
  <div class="mt-6 app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">Prospect Tracking</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b app-border">
            <th class="text-left py-2 app-text font-medium">Prospect</th>
            <th class="text-right py-2 app-text font-medium">Views</th>
            <th class="text-right py-2 app-text font-medium">Visitors</th>
            <th class="text-right py-2 app-text font-medium">Video Plays</th>
            <th class="text-right py-2 app-text font-medium">Waitlist</th>
            <th class="text-right py-2 app-text font-medium">CTA Clicks</th>
            <th class="text-right py-2 app-text font-medium">Last Active</th>
          </tr>
        </thead>
        <tbody>
          <% @data[:prospect_tracking].each do |prospect| %>
            <tr class="border-b app-border">
              <td class="py-2 app-text font-medium"><%= prospect[:prospect] %></td>
              <td class="text-right py-2 app-text-muted"><%= prospect[:page_views] %></td>
              <td class="text-right py-2 app-text-muted"><%= prospect[:unique_visitors] %></td>
              <td class="text-right py-2 app-text-muted"><%= prospect[:video_plays] %></td>
              <td class="text-right py-2 app-text-muted">
                <% if prospect[:waitlist_submits] > 0 %>
                  <span class="text-green-600 dark:text-green-400 font-semibold"><%= prospect[:waitlist_submits] %></span>
                <% else %>
                  <%= prospect[:waitlist_submits] %>
                <% end %>
              </td>
              <td class="text-right py-2 app-text-muted"><%= prospect[:cta_clicks] %></td>
              <td class="text-right py-2 app-text-muted whitespace-nowrap"><%= time_ago_in_words(prospect[:last_active]) %> ago</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<!-- Three-column: UTM Sources + UTM Content + Devices -->
<div class="mt-6 grid lg:grid-cols-3 gap-6">
  <div class="app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">UTM Sources</h2>
    <% if @data[:utm_breakdown].any? %>
      <div class="space-y-2">
        <% @data[:utm_breakdown].each do |utm| %>
          <div class="flex justify-between items-center text-sm">
            <span class="app-text truncate mr-2"><%= utm[:source] %></span>
            <span class="app-text-muted flex-shrink-0"><%= number_with_delimiter(utm[:visitors]) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm app-text-muted">No UTM data yet</p>
    <% end %>
  </div>

  <div class="app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">UTM Content</h2>
    <% if @data[:utm_content_breakdown].any? %>
      <div class="space-y-2">
        <% @data[:utm_content_breakdown].each do |utm| %>
          <div class="flex justify-between items-center text-sm">
            <span class="app-text truncate mr-2"><%= utm[:content] %></span>
            <span class="app-text-muted flex-shrink-0"><%= number_with_delimiter(utm[:visitors]) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm app-text-muted">No UTM content yet</p>
    <% end %>
  </div>

  <div class="app-surface rounded-xl border app-border p-5">
    <h2 class="text-sm font-semibold app-text mb-4">Devices & Browsers</h2>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <p class="text-xs app-text-muted mb-2">Device Type</p>
        <% if @data[:device_breakdown].any? %>
          <% @data[:device_breakdown].sort_by { |_, v| -v }.each do |device, count| %>
            <div class="flex justify-between items-center text-sm mb-1">
              <span class="app-text capitalize"><%= device %></span>
              <span class="app-text-muted"><%= number_with_delimiter(count) %></span>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm app-text-muted">No data</p>
        <% end %>
      </div>
      <div>
        <p class="text-xs app-text-muted mb-2">Browser</p>
        <% if @data[:browser_breakdown].any? %>
          <% @data[:browser_breakdown].sort_by { |_, v| -v }.each do |browser, count| %>
            <div class="flex justify-between items-center text-sm mb-1">
              <span class="app-text"><%= browser %></span>
              <span class="app-text-muted"><%= number_with_delimiter(count) %></span>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm app-text-muted">No data</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
