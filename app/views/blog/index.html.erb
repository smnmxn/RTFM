<% content_for :title, "Blog - supportpages.io" %>
<% content_for :head do %>
  <meta name="description" content="Latest updates, insights, and announcements from the supportpages.io team. Learn about automated documentation, AI-powered help centers, and developer documentation best practices.">
  <meta property="og:title" content="Blog - supportpages.io">
  <meta property="og:description" content="Latest updates, insights, and announcements from the supportpages.io team.">
  <meta property="og:url" content="<%= blog_url %>">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Blog - supportpages.io">
  <meta name="twitter:description" content="Latest updates, insights, and announcements from the supportpages.io team.">
<% end %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Hero section -->
  <div class="mb-16">
    <div class="inline-block mb-4">
      <span class="text-sm font-medium text-zinc-500 uppercase tracking-wider">The Blog</span>
    </div>
    <h1 class="text-5xl sm:text-6xl font-bold text-white mb-6 leading-tight" style="font-family: 'Space Grotesk', sans-serif;">
      SupportPages.io
    </h1>
    <p class="text-xl text-zinc-400 max-w-2xl leading-relaxed">
      SaaS lessons from 2009 to now. What's changed, what hasn't.
    </p>
  </div>

  <!-- Blog posts -->
  <% if @posts.any? %>
    <div class="space-y-6">
      <% @posts.each do |post| %>
        <article class="group">
          <a href="<%= blog_post_path(post[:slug]) %>" class="block">
            <div class="relative bg-gradient-to-br from-zinc-900/90 to-zinc-900/50 border border-zinc-800/50 rounded-xl overflow-hidden hover:border-zinc-700/80 transition-all duration-300 hover:shadow-lg hover:shadow-zinc-900/50">
              <!-- Subtle gradient overlay on hover -->
              <div class="absolute inset-0 bg-gradient-to-br from-zinc-800/0 to-zinc-800/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

              <% if post[:image].present? %>
                <div class="aspect-[2/1] overflow-hidden bg-zinc-800">
                  <img src="<%= post[:image] %>"
                       alt="<%= post[:title] %>"
                       class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                </div>
              <% end %>

              <div class="relative p-8">
                <!-- Post meta -->
                <div class="flex items-center gap-3 text-sm text-zinc-500 mb-4">
                  <% if post[:date].present? %>
                    <time datetime="<%= post[:date].iso8601 %>" class="font-medium">
                      <%= post[:date].strftime("%b %d, %Y") %>
                    </time>
                  <% end %>
                  <% if post[:author].present? %>
                    <span class="text-zinc-700">•</span>
                    <span class="text-zinc-500"><%= post[:author] %></span>
                  <% end %>
                  <% if !post[:published] && !Rails.env.production? %>
                    <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-500/20 text-yellow-300 border border-yellow-500/30">
                      Draft
                    </span>
                  <% end %>
                </div>

                <!-- Post title -->
                <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3 group-hover:text-zinc-50 transition-colors leading-tight" style="font-family: 'Space Grotesk', sans-serif;">
                  <%= post[:title] %>
                </h2>

                <!-- Post excerpt -->
                <% if post[:excerpt].present? %>
                  <p class="text-zinc-400 text-base leading-relaxed mb-5 line-clamp-2">
                    <%= post[:excerpt] %>
                  </p>
                <% end %>

                <!-- Read more link -->
                <div class="inline-flex items-center text-sm font-semibold text-zinc-300 group-hover:text-white transition-colors">
                  <span>Read article</span>
                  <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </div>
              </div>
            </div>
          </a>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-zinc-900/50 border border-zinc-800/50 mb-4">
        <svg class="w-8 h-8 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" />
        </svg>
      </div>
      <p class="text-zinc-500 text-lg">No blog posts yet. Check back soon!</p>
    </div>
  <% end %>
</div>
