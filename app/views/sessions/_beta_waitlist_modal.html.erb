<div data-controller="beta-waitlist-modal"
     data-beta-waitlist-modal-url-value="<%= waitlist_path %>">

  <!-- Backdrop -->
  <div data-beta-waitlist-modal-target="backdrop"
       data-action="click->beta-waitlist-modal#close"
       class="hidden fixed inset-0 z-40"
       style="background-color: rgba(0, 0, 0, 0.75);">
  </div>

  <!-- Modal Dialog -->
  <div data-beta-waitlist-modal-target="dialog"
       class="hidden fixed inset-0 z-50">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="relative w-full max-w-md bg-zinc-900/95 backdrop-blur-xl rounded-2xl shadow-2xl border border-zinc-700"
           data-action="click->beta-waitlist-modal#stopPropagation">

        <!-- Close button -->
        <button type="button"
                data-action="beta-waitlist-modal#close"
                class="absolute top-4 right-4 text-zinc-400 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

        <!-- Form Container -->
        <div data-beta-waitlist-modal-target="formContainer" class="px-8 py-10">
          <!-- Header -->
          <div class="text-center mb-6">
            <div class="text-4xl mb-3">🚀</div>
            <h3 class="text-2xl font-bold text-white mb-2">
              We're in private beta
            </h3>
            <p class="text-zinc-300 text-sm leading-relaxed">
              Love what you see? Join our waitlist for early access to SupportPages.
            </p>
          </div>

          <!-- Email input -->
          <div class="space-y-3">
            <input type="email"
                   data-beta-waitlist-modal-target="emailInput"
                   placeholder="you@example.com"
                   required
                   class="w-full px-4 py-3 bg-zinc-800/50 border border-zinc-700 rounded-lg text-sm text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:border-zinc-400 transition-all">

            <button type="button"
                    data-action="beta-waitlist-modal#submit"
                    data-beta-waitlist-modal-target="submitButton"
                    class="w-full px-4 py-3 bg-white text-zinc-950 font-semibold rounded-lg hover:bg-zinc-100 transition-all text-sm">
              Join Waitlist
            </button>
          </div>
        </div>

        <!-- Success Container (hidden initially) -->
        <div class="hidden px-8 py-10" data-beta-waitlist-modal-target="successContainer">
          <div class="text-center">
            <div class="text-5xl mb-4">✅</div>
            <h3 class="text-2xl font-bold text-white mb-2">
              You're on the list!
            </h3>
            <p class="text-zinc-300 text-sm">
              We'll reach out when your access is ready.
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
