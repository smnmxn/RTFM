<% content_for(:head) do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

  <meta name="description" content="SupportPages reads your code and keeps your help centre up to date - every merge, no backlog.">
  <meta property="og:title" content="SupportPages.io - Your help centre, always up to date">
  <meta property="og:description" content="SupportPages reads your code and keeps your help centre up to date - every merge, no backlog.">
  <meta property="og:image" content="https://supportpages.io/images/og-home.png">
  <meta property="og:url" content="https://supportpages.io">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="SupportPages.io - Your help centre, always up to date">
  <meta name="twitter:description" content="SupportPages reads your code and keeps your help centre up to date - every merge, no backlog.">
  <meta name="twitter:image" content="https://supportpages.io/images/og-home.png">

  <script>
    // Prevent native hash-jump on page load. The smooth-scroll controller
    // handles scrolling to the anchor instead (via sessionStorage).
    if (window.location.hash) {
      var h = window.location.hash.substring(1);
      history.replaceState(null, "", window.location.pathname + window.location.search);
      // Store so the smooth-scroll controller can pick it up
      sessionStorage.setItem("smoothScrollTarget", h);
      // Force scroll to top before browser can jump
      window.scrollTo(0, 0);
      document.addEventListener("DOMContentLoaded", function() { window.scrollTo(0, 0); });
    }
  </script>
<% end %>

<div class="bg-zinc-950 min-h-screen relative overflow-hidden" style="font-family: 'Inter', system-ui, sans-serif;"
     data-controller="analytics login-toggle"
     data-action="video-player:played->analytics#videoPlayed"
>

  <!-- Animated gradient orbs -->
  <div class="absolute top-[-20%] left-[-10%] w-[600px] h-[600px] rounded-full bg-zinc-500/12 blur-3xl animate-orb-1 pointer-events-none"></div>
  <div class="absolute top-[30%] right-[-15%] w-[500px] h-[500px] rounded-full bg-zinc-400/12 blur-3xl animate-orb-2 pointer-events-none"></div>
  <div class="absolute bottom-[-10%] left-[20%] w-[400px] h-[400px] rounded-full bg-zinc-600/12 blur-3xl animate-orb-3 pointer-events-none"></div>

  <!-- Header overlay -->
  <%= render "shared/public_header", active: "login", theme: "dark" %>

  <!-- Main content -->
  <div class="relative z-10 flex flex-col items-center px-4 pt-28 pb-16">

    <!-- Hero headline -->
    <h1 class="text-gradient-hero text-5xl sm:text-6xl md:text-7xl font-extrabold text-center leading-tight tracking-tight max-w-4xl" style="font-family: 'Space Grotesk', system-ui, sans-serif;">
      Your help centre is out of date the moment you ship.
    </h1>

    <!-- Subtitle -->
    <p class="mt-6 text-lg sm:text-xl text-zinc-400 text-center max-w-2xl leading-relaxed">
      SupportPages reads your code and updates your help centre automatically - every merge, no backlog.
    </p>

    <!-- Video player -->
    <div class="mt-12 w-full max-w-3xl"
         data-controller="video-player tilt"
         data-action="mousemove->tilt#move mouseleave->tilt#leave video-player:played->tilt#disable">
      <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-zinc-500/10"
           data-tilt-target="inner">
        <!-- Glare overlay -->
        <div class="absolute inset-0 z-20 pointer-events-none rounded-2xl" data-tilt-target="glare"></div>
        <!-- Video (always visible, autoplays muted) -->
        <video
          data-video-player-target="video"
          class="w-full rounded-2xl"
          preload="metadata"
          autoplay
          muted
          loop
          playsinline
        >
          <source src="/videos/supportpagesexplainer.mp4?v=2" type="video/mp4">
          <track
            kind="captions"
            src="/videos/supportpagesexplainer.vtt"
            srclang="en"
            label="English"
          >
          Your browser does not support the video tag.
        </video>

        <!-- Poster overlay (sits on top of playing video) -->
        <div
          data-video-player-target="poster"
          data-action="click->video-player#play"
          class="absolute inset-0 flex flex-col items-center justify-center bg-zinc-950/60 backdrop-blur-sm cursor-pointer group transition-opacity duration-300"
        >
          <!-- Play button -->
          <div class="w-20 h-20 bg-white/15 backdrop-blur-sm rounded-full flex items-center justify-center group-hover:bg-white/25 group-hover:scale-110 transition-all duration-300 shadow-2xl mb-4 border border-white/20">
            <svg class="w-10 h-10 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <p class="text-white text-lg font-semibold mb-1">See how it works</p>
          <p class="text-white/60 text-sm">90 second demo</p>
        </div>
      </div>
    </div>

    <!-- Flash messages -->
    <% if flash[:notice] %>
      <div class="mt-8 w-full max-w-md mx-auto bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 px-4 py-3 rounded-lg text-sm text-center">
        <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="mt-8 w-full max-w-md mx-auto bg-red-500/10 border border-red-500/30 text-red-300 px-4 py-3 rounded-lg text-sm text-center">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- CTA -->
    <div id="hero-cta" class="mt-12 flex flex-col items-center gap-3">
      <button data-action="click->login-toggle#open"
              data-login-toggle-mode-param="register"
              class="btn-glow flex items-center justify-center px-10 py-4 bg-white text-zinc-950 font-semibold rounded-xl hover:bg-zinc-100 transition-all duration-200 text-lg cursor-pointer">
        Get started free
      </button>
      <p class="text-sm text-zinc-500">
        Already have an account?
        <button data-action="click->login-toggle#open"
                data-login-toggle-mode-param="signin"
                class="text-zinc-300 hover:text-white underline cursor-pointer bg-transparent border-0 p-0 text-sm">Sign in</button>
      </p>
      <p class="text-xs text-zinc-600 mt-1">No credit card required</p>
    </div>

    <% if session[:invite_token].present? %>
      <p class="mt-3 text-center text-zinc-300 text-sm font-medium">Your invite is ready</p>
    <% end %>

  </div>

  <!-- Social proof - open source help centres -->
  <div class="relative z-10 py-12 border-t border-zinc-800/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-xl font-bold text-white mb-2" style="font-family: 'Space Grotesk', system-ui, sans-serif;">See SupportPages in action</h2>
      <p class="text-center text-sm text-zinc-500 mb-8">These help centres were generated entirely from code — no manual writing</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="https://wordpress.supportpages.io" target="_blank" class="group bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 p-5 hover:border-zinc-700 transition-colors">
          <img src="/images/logos/wordpress.png" alt="WordPress" class="w-full h-auto rounded-lg mb-3">
          <h3 class="font-medium text-white text-sm mb-1">WordPress</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Help centre for the world's most popular content management system</p>
          <span class="inline-flex items-center gap-1 mt-3 text-xs text-zinc-600 group-hover:text-zinc-400 transition-colors">
            View help centre
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </span>
        </a>
        <a href="https://docuseal.supportpages.io" target="_blank" class="group bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 p-5 hover:border-zinc-700 transition-colors">
          <img src="/images/logos/docuseal.png" alt="DocuSeal" class="w-full h-auto rounded-lg mb-3">
          <h3 class="font-medium text-white text-sm mb-1">DocuSeal</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">SupportPages for document signing and form filling</p>
          <span class="inline-flex items-center gap-1 mt-3 text-xs text-zinc-600 group-hover:text-zinc-400 transition-colors">
            View help centre
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </span>
        </a>
        <a href="https://cal.supportpages.io" target="_blank" class="group bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 p-5 hover:border-zinc-700 transition-colors">
          <img src="/images/logos/cal.png" alt="Cal.com" class="w-full h-auto rounded-lg mb-3">
          <h3 class="font-medium text-white text-sm mb-1">Cal.com</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">User support for the scheduling platform built for scale</p>
          <span class="inline-flex items-center gap-1 mt-3 text-xs text-zinc-600 group-hover:text-zinc-400 transition-colors">
            View help centre
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </span>
        </a>
        <a href="https://plausible.supportpages.io" target="_blank" class="group bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 p-5 hover:border-zinc-700 transition-colors">
          <img src="/images/logos/plausible.png" alt="Plausible" class="w-full h-auto rounded-lg mb-3">
          <h3 class="font-medium text-white text-sm mb-1">Plausible</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">Help docs for privacy-friendly web analytics</p>
          <span class="inline-flex items-center gap-1 mt-3 text-xs text-zinc-600 group-hover:text-zinc-400 transition-colors">
            View help centre
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </span>
        </a>
      </div>
    </div>
  </div>

  <!-- Integrations -->
  <div class="relative z-10 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-medium text-zinc-600 uppercase tracking-wider mb-8">Works with your code hosting platform</p>
      <div class="flex items-center justify-center gap-6 sm:gap-10 flex-wrap">
        <!-- GitHub -->
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 flex items-center justify-center">
            <svg class="w-6 h-6 text-zinc-300" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="text-xs text-zinc-500">GitHub</span>
        </div>
        <!-- GitLab -->
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 flex items-center justify-center">
            <svg class="w-6 h-6 text-zinc-300" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 01-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 014.82 2a.43.43 0 01.58 0 .42.42 0 01.11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0118.6 2a.43.43 0 01.58 0 .42.42 0 01.11.18l2.44 7.51L23 13.45a.84.84 0 01-.35.94z"/>
            </svg>
          </div>
          <span class="text-xs text-zinc-500">GitLab</span>
        </div>
        <!-- Bitbucket -->
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 flex items-center justify-center">
            <svg class="w-6 h-6 text-zinc-300" viewBox="0 0 24 24" fill="currentColor">
              <path d="M2.65 3A1 1 0 001.67 4.2l2.75 16.52a1.33 1.33 0 001.33 1.09h12.59a1 1 0 001-.78L22.33 4.2A1 1 0 0021.35 3H2.65zm11.45 13H9.91L8.8 10h6.34z"/>
            </svg>
          </div>
          <span class="text-xs text-zinc-500">Bitbucket</span>
        </div>
        <!-- Azure DevOps -->
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 flex items-center justify-center">
            <svg class="w-6 h-6 text-zinc-300" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22 4v16l-6 2-8.5-2.9V22l-4-5.2h18.5V4zM2 7.96l4.5-1.46v10l-4.5-.5V7.96zM8 6l12-4v5H8z"/>
            </svg>
          </div>
          <span class="text-xs text-zinc-500">Azure DevOps</span>
        </div>
      </div>
    </div>
  </div>

  <!-- How it works - 3 step summary -->
  <div class="relative z-10 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl sm:text-3xl font-bold text-white mb-12" style="font-family: 'Space Grotesk', system-ui, sans-serif;">
        Three steps to a help centre that never goes stale
      </h2>
      <div class="grid sm:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 mx-auto bg-zinc-800 border border-zinc-700 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-zinc-300" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
          </div>
          <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider mb-1">Step 1</p>
          <h3 class="font-semibold text-white mb-2">Connect your repo</h3>
          <p class="text-sm text-zinc-400">Install the GitHub App and select which repositories to watch.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto bg-zinc-800 border border-zinc-700 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-zinc-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
            </svg>
          </div>
          <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider mb-1">Step 2</p>
          <h3 class="font-semibold text-white mb-2">AI writes your help articles</h3>
          <p class="text-sm text-zinc-400">Your codebase is analysed and help articles are generated automatically.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto bg-zinc-800 border border-zinc-700 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-zinc-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582" />
            </svg>
          </div>
          <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider mb-1">Step 3</p>
          <h3 class="font-semibold text-white mb-2">Publish your help centre</h3>
          <p class="text-sm text-zinc-400">Review, approve, and publish to your branded help centre.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Features -->
  <div class="relative z-10">
    <%= render "shared/features" %>
  </div>

  <!-- Closing CTA -->
  <div class="relative z-10 text-center py-20 px-4">
    <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4" style="font-family: 'Space Grotesk', system-ui, sans-serif;">
      Ready to automate your help centre?
    </h2>
    <p class="text-zinc-400 mb-8 max-w-lg mx-auto">
      Set up in minutes. Free to start. No credit card required.
    </p>
    <div class="flex flex-col items-center gap-3">
      <button data-action="click->login-toggle#open"
              data-login-toggle-mode-param="register"
              class="inline-flex items-center justify-center px-10 py-4 bg-white text-zinc-950 font-semibold rounded-xl hover:bg-zinc-100 transition-all duration-200 text-lg cursor-pointer">
        Get started free
      </button>
      <p class="text-sm text-zinc-500">
        Already have an account?
        <button data-action="click->login-toggle#open"
                data-login-toggle-mode-param="signin"
                class="text-zinc-300 hover:text-white underline cursor-pointer bg-transparent border-0 p-0 text-sm">Sign in</button>
      </p>
    </div>
  </div>

  <!-- Dark footer -->
  <footer class="relative z-10 border-t border-zinc-800/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex items-center justify-between text-xs text-zinc-600">
      <span>&copy; <%= Date.current.year %> Surface Layer Limited (Company No. 17026012) | 128 City Road, London, EC1V 2NX</span>
      <nav class="flex gap-4">
        <a href="/pricing" class="hover:text-zinc-400 transition-colors">Pricing</a>
        <a href="/blog" class="hover:text-zinc-400 transition-colors">Blog</a>
        <a href="/legal/privacy" class="hover:text-zinc-400 transition-colors">Privacy</a>
        <a href="/legal/terms" class="hover:text-zinc-400 transition-colors">Terms</a>
      </nav>
    </div>
  </footer>

  <!-- Auth Modal (backdrop + dialog in one layer) -->
  <div data-login-toggle-target="backdrop" class="hidden fixed inset-0 z-40 bg-black/70 backdrop-blur-sm"></div>
  <div data-login-toggle-target="modal"
       data-action="click->login-toggle#close"
       class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="relative w-full max-w-md bg-zinc-900/95 backdrop-blur-xl rounded-2xl shadow-2xl border border-zinc-700/50"
           data-action="click->login-toggle#stopPropagation">

        <!-- Close button -->
        <button data-action="click->login-toggle#close"
                class="absolute top-4 right-4 text-zinc-400 hover:text-white transition-colors cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

        <div class="px-8 pt-8 pb-6">
          <!-- Modal header -->
          <div class="text-center mb-6">
            <h2 data-login-toggle-target="modalTitle" class="text-xl font-bold text-white">Welcome back</h2>
            <p data-login-toggle-target="modalSubtitle" class="text-sm text-zinc-400 mt-1">Sign in to your account</p>
          </div>

          <!-- OAuth buttons -->
          <div class="flex flex-col gap-2.5">
            <%= button_to "/auth/github", method: :post, data: { turbo: false }, class: "flex items-center justify-center gap-3 px-5 py-2.5 bg-white text-zinc-950 font-semibold rounded-xl hover:bg-zinc-100 transition-all duration-200 text-sm w-full cursor-pointer" do %>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
              </svg>
              <span>Continue with GitHub</span>
            <% end %>

            <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "flex items-center justify-center gap-3 px-5 py-2.5 bg-zinc-800/50 border border-zinc-700 text-zinc-200 font-medium rounded-xl hover:bg-zinc-700/50 transition-all duration-200 text-sm w-full cursor-pointer" do %>
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <span>Continue with Google</span>
            <% end %>

            <% if ENV["APPLE_CLIENT_ID"].present? %>
              <%= button_to "/auth/apple", method: :post, data: { turbo: false }, class: "flex items-center justify-center gap-3 px-5 py-2.5 bg-zinc-800/50 border border-zinc-700 text-zinc-200 font-medium rounded-xl hover:bg-zinc-700/50 transition-all duration-200 text-sm w-full cursor-pointer" do %>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
                </svg>
                <span>Continue with Apple</span>
              <% end %>
            <% end %>
          </div>

          <!-- Divider -->
          <div class="relative my-6">
            <div class="absolute inset-0 flex items-center">
              <div class="w-full border-t border-zinc-800"></div>
            </div>
            <div class="relative flex justify-center text-xs">
              <span class="px-3 bg-zinc-900 text-zinc-500">or</span>
            </div>
          </div>

          <!-- Sign in form -->
          <div data-login-toggle-target="signInForm">
            <%= form_with url: login_with_password_path, method: :post, data: { turbo: false }, class: "flex flex-col gap-3" do |f| %>
              <input type="email" name="email" placeholder="Email address" required
                     class="px-4 py-2.5 bg-zinc-800/50 border border-zinc-800 rounded-xl text-sm text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:border-zinc-400 transition-all" />
              <input type="password" name="password" placeholder="Password" required
                     class="px-4 py-2.5 bg-zinc-800/50 border border-zinc-800 rounded-xl text-sm text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:border-zinc-400 transition-all" />
              <button type="submit" class="px-5 py-2.5 bg-white text-zinc-950 font-semibold rounded-xl hover:bg-zinc-100 transition-all text-sm cursor-pointer">
                Log in
              </button>
            <% end %>
          </div>

          <!-- Register form (hidden by default) -->
          <div data-login-toggle-target="registerForm" class="hidden">
            <%= form_with url: register_path, method: :post, data: { turbo: false }, class: "flex flex-col gap-3" do |f| %>
              <input type="text" name="name" placeholder="Full name" required
                     class="px-4 py-2.5 bg-zinc-800/50 border border-zinc-800 rounded-xl text-sm text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:border-zinc-400 transition-all" />
              <input type="email" name="email" placeholder="Email address" required
                     class="px-4 py-2.5 bg-zinc-800/50 border border-zinc-800 rounded-xl text-sm text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:border-zinc-400 transition-all" />
              <input type="password" name="password" placeholder="Password (min 8 characters)" required minlength="8"
                     class="px-4 py-2.5 bg-zinc-800/50 border border-zinc-800 rounded-xl text-sm text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:border-zinc-400 transition-all" />
              <input type="password" name="password_confirmation" placeholder="Confirm password" required
                     class="px-4 py-2.5 bg-zinc-800/50 border border-zinc-800 rounded-xl text-sm text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:border-zinc-400 transition-all" />
              <button type="submit" class="px-5 py-2.5 bg-white text-zinc-950 font-semibold rounded-xl hover:bg-zinc-100 transition-all text-sm cursor-pointer">
                Create account
              </button>
            <% end %>
          </div>

          <!-- Toggle link -->
          <p class="mt-4 text-center text-zinc-500 text-sm">
            <span data-login-toggle-target="toggleText">Don't have an account?</span>
            <button data-login-toggle-target="toggleLink"
                    data-action="click->login-toggle#showRegister"
                    class="text-zinc-300 hover:text-white underline cursor-pointer ml-1">Sign up</button>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<% content_for(:footer) do %>
  <!-- replaced by in-page dark footer -->
<% end %>
