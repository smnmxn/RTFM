<%= turbo_frame_tag "inbox-editor", class: "h-full block" do %>
  <div class="h-full flex items-center justify-center app-surface">
    <div class="text-center px-6 max-w-md">
      <%= heroicon "exclamation-triangle", options: { class: "mx-auto h-20 w-20 text-amber-400" } %>

      <h3 class="mt-6 text-2xl font-semibold app-text">Article limit reached</h3>

      <p class="mt-4 app-text-secondary">
        You've reached your plan limit of <%= limit %> articles. Upgrade your plan to create more.
      </p>

      <div class="mt-8">
        <%= link_to billing_path,
            class: "inline-flex items-center gap-2 px-6 py-3 app-accent-bg text-white font-medium rounded-lg hover:app-accent-bg" do %>
          Upgrade plan
          <%= heroicon "arrow-up-circle", options: { class: "w-4 h-4" } %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
