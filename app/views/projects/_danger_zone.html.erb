<%# locals: (project:) %>
<!-- Maintenance -->
<div class="border app-border rounded-lg mb-6">
  <div class="px-4 py-3 app-surface-secondary border-b app-border rounded-t-lg">
    <h3 class="text-lg font-medium app-text">Maintenance</h3>
  </div>

  <div class="p-4 flex items-center justify-between">
    <div>
      <h4 class="text-sm font-medium app-text">Re-analyze Codebase</h4>
      <p class="text-sm app-text-secondary">Re-run the codebase analysis, CSS extraction, and image extraction.</p>
    </div>
    <%= button_to "Re-analyze...",
        reanalyze_project_path(project),
        method: :post,
        class: "ml-4 shrink-0 px-4 py-2 border app-border text-sm font-medium rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors app-text",
        disabled: project.analysis_status == "running",
        data: { turbo_confirm: "This will re-analyze the codebase, regenerate CSS, and re-extract images. It may take a few minutes." } %>
  </div>
</div>

<!-- Danger Zone -->
<div class="border border-red-200 rounded-lg">
  <div class="px-4 py-3 bg-red-50 border-b border-red-200 rounded-t-lg">
    <h3 class="text-lg font-medium text-red-600">Danger Zone</h3>
  </div>

  <div class="divide-y divide-red-200">
    <!-- Start Over -->
    <div class="p-4 flex items-center justify-between">
      <div>
        <h4 class="text-sm font-medium app-text">Start Over</h4>
        <p class="text-sm app-text-secondary">Clear all articles and sections, then re-run the setup wizard.</p>
      </div>
      <%= button_to "Start Over...",
          start_over_project_path(project),
          method: :post,
          class: "ml-4 shrink-0 px-4 py-2 border border-red-300 text-red-600 rounded-lg hover:bg-red-50 transition-colors text-sm font-medium",
          data: { turbo_confirm: "Are you sure you want to start over? This will delete all articles, sections, and recommendations. You'll need to go through the setup wizard again." } %>
    </div>

    <!-- Delete Project -->
    <div class="p-4 flex items-center justify-between">
      <div>
        <h4 class="text-sm font-medium app-text">Delete Project</h4>
        <p class="text-sm app-text-secondary">Permanently delete this project and all its data.</p>
      </div>
      <%= button_to "Delete Project...",
          project_path(project),
          method: :delete,
          class: "ml-4 shrink-0 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors text-sm font-medium",
          data: { turbo_confirm: "Are you sure you want to delete this project? This will permanently remove all articles, sections, and data. This action cannot be undone." } %>
    </div>
  </div>
</div>
