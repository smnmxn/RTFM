<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "supportpages.io" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="supportpages.io">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# Removed turbo_refreshes_with morph - it can cause CSS to not load on page refresh %>

    <%# Prevent flash of wrong theme — must run before stylesheet %>
    <script>
      (function(){
        var t = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (t === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>

    <%# Inter (body) + Space Grotesk (headlines/logo) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tippy.js@6.3.7/dist/tippy.css">

    <!-- Code syntax highlighting (JS loaded via importmap, CSS themes here) -->
    <link rel="stylesheet" id="hljs-light" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github.min.css" data-turbo-track="reload">
    <link rel="stylesheet" id="hljs-dark" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github-dark.min.css" data-turbo-track="reload" disabled>
    <script>
      // Swap hljs theme based on dark mode class
      (function() {
        var isDark = document.documentElement.classList.contains('dark');
        document.getElementById('hljs-light').disabled = isDark;
        document.getElementById('hljs-dark').disabled = !isDark;
      })();
    </script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen flex flex-col" style="font-family: var(--app-font-body);">
    <div data-controller="presence"></div>
    <div class="flex-1 app-bg">
      <%= yield %>
    </div>
    <%= render "shared/toasts" %>

    <% if content_for?(:footer) %>
      <%= yield :footer %>
    <% else %>
      <footer class="app-surface border-t app-border mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 text-xs app-text-muted">
          <span>&copy; <%= Date.current.year %> Surface Layer Limited (Company No. 17026012) | 128 City Road, London, EC1V 2NX</span>
          <nav class="flex gap-4">
            <a href="/legal/privacy" class="hover:app-text transition-colors">Privacy</a>
            <a href="/legal/terms" class="hover:app-text transition-colors">Terms</a>
            <a href="/legal" class="hover:app-text transition-colors">Trust Center</a>
          </nav>
        </div>
      </footer>
    <% end %>
  </body>
</html>
