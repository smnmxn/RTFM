<% content_for(:title) { "How it Works - supportpages.io" } %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Hero -->
  <div class="text-center mb-16">
    <h1 class="text-gradient-hero text-5xl sm:text-6xl md:text-7xl font-extrabold mb-5 leading-tight tracking-tight" style="font-family: 'Space Grotesk', system-ui, sans-serif;">
      How it Works
    </h1>
    <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed">
      From code change to published help article in minutes. No manual writing. No content debt.
    </p>
  </div>

  <!-- Steps timeline -->
  <div class="space-y-0 mb-16">
    <!-- Step 1 -->
    <div class="flex gap-5">
      <div class="flex flex-col items-center">
        <div class="w-px flex-1 bg-transparent"></div>
        <div class="w-12 h-12 bg-zinc-800 border border-zinc-700 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-zinc-300" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="w-px flex-1 bg-zinc-800"></div>
      </div>
      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 p-6 flex-1 mb-6">
        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Step 1</p>
        <h3 class="text-lg font-semibold text-white mb-2">Connect your GitHub repos</h3>
        <p class="text-zinc-400 leading-relaxed">
          Install the GitHub App and select which repositories to watch. Setup takes less than a minute. No configuration files or CI pipelines needed.
        </p>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="flex gap-5">
      <div class="flex flex-col items-center">
        <div class="w-px flex-1 bg-zinc-800"></div>
        <div class="w-12 h-12 bg-zinc-800 border border-zinc-700 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-zinc-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </div>
        <div class="w-px flex-1 bg-zinc-800"></div>
      </div>
      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 p-6 flex-1 mb-6">
        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Step 2</p>
        <h3 class="text-lg font-semibold text-white mb-2">AI analyzes every code change</h3>
        <p class="text-zinc-400 leading-relaxed">
          When pull requests are merged, the system reads the diff automatically. It understands what changed and why it matters to your users, not just what the code does.
        </p>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="flex gap-5">
      <div class="flex flex-col items-center">
        <div class="w-px flex-1 bg-zinc-800"></div>
        <div class="w-12 h-12 bg-zinc-800 border border-zinc-700 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-zinc-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <div class="w-px flex-1 bg-zinc-800"></div>
      </div>
      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 p-6 flex-1 mb-6">
        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Step 3</p>
        <h3 class="text-lg font-semibold text-white mb-2">Help articles are generated</h3>
        <p class="text-zinc-400 leading-relaxed">
          AI writes clear, user-friendly documentation with step-by-step guides. Draft articles land in your inbox for review. Nothing gets published without your approval.
        </p>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="flex gap-5">
      <div class="flex flex-col items-center">
        <div class="w-px flex-1 bg-zinc-800"></div>
        <div class="w-12 h-12 bg-zinc-800 border border-zinc-700 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-zinc-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
        </div>
        <div class="w-px flex-1 bg-transparent"></div>
      </div>
      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 p-6 flex-1">
        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider mb-2">Step 4</p>
        <h3 class="text-lg font-semibold text-white mb-2">Publish to your branded help centre</h3>
        <p class="text-zinc-400 leading-relaxed">
          One-click publish to your custom subdomain or domain. Built-in AI-powered Q&amp;A lets your users ask questions and get instant answers. Articles auto-update as your code evolves.
        </p>
      </div>
    </div>
  </div>

  <!-- Key features -->
  <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800 p-6 mb-16">
    <h2 class="text-lg font-semibold text-white mb-4">Key Features</h2>
    <div class="grid md:grid-cols-2 gap-4">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-emerald-500/15 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <div>
          <p class="font-medium text-white">Automatic updates</p>
          <p class="text-sm text-zinc-400">Articles stay current as your code evolves</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-emerald-500/15 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <div>
          <p class="font-medium text-white">AI-powered Q&amp;A</p>
          <p class="text-sm text-zinc-400">End users ask questions and get instant answers</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-emerald-500/15 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <div>
          <p class="font-medium text-white">Custom branding</p>
          <p class="text-sm text-zinc-400">Your logo, colors, and custom domain</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-emerald-500/15 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <div>
          <p class="font-medium text-white">Human review</p>
          <p class="text-sm text-zinc-400">Every article goes through your inbox first</p>
        </div>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="mb-16" data-controller="accordion">
    <h2 class="text-lg font-semibold text-white mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3">

      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800" data-accordion-target="item">
        <button class="w-full flex items-center justify-between p-5 text-left" data-action="click->accordion#toggle">
          <span class="font-medium text-white pr-4">Does SupportPages work with Azure DevOps, GitLab, or Bitbucket?</span>
          <svg data-role="icon" class="w-5 h-5 text-zinc-400 flex-shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div data-role="answer" class="overflow-hidden transition-all duration-200" style="max-height: 0px;">
          <p class="px-5 pb-5 text-zinc-400 leading-relaxed">
            Not yet. We support GitHub today, with GitLab, Bitbucket, and Azure DevOps on our roadmap. If one of these is important to you, let us know &mdash; it helps us prioritise.
          </p>
        </div>
      </div>

      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800" data-accordion-target="item">
        <button class="w-full flex items-center justify-between p-5 text-left" data-action="click->accordion#toggle">
          <span class="font-medium text-white pr-4">Is my source code secure? Do you store it?</span>
          <svg data-role="icon" class="w-5 h-5 text-zinc-400 flex-shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div data-role="answer" class="overflow-hidden transition-all duration-200" style="max-height: 0px;">
          <p class="px-5 pb-5 text-zinc-400 leading-relaxed">
            We never store your source code. Each analysis runs in an isolated sandbox that is destroyed immediately after processing. Only Anthropic sees the code under a strict data processing agreement. Read more on our <a href="/legal/security" class="text-white underline hover:text-zinc-300">security page</a>.
          </p>
        </div>
      </div>

      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800" data-accordion-target="item">
        <button class="w-full flex items-center justify-between p-5 text-left" data-action="click->accordion#toggle">
          <span class="font-medium text-white pr-4">Can SupportPages run inside our own infrastructure?</span>
          <svg data-role="icon" class="w-5 h-5 text-zinc-400 flex-shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div data-role="answer" class="overflow-hidden transition-all duration-200" style="max-height: 0px;">
          <p class="px-5 pb-5 text-zinc-400 leading-relaxed">
            Not currently, but we're exploring it. Our Docker-based architecture means the analysis container could run in your own environment. Get in touch if self-hosting is a hard requirement.
          </p>
        </div>
      </div>

      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800" data-accordion-target="item">
        <button class="w-full flex items-center justify-between p-5 text-left" data-action="click->accordion#toggle">
          <span class="font-medium text-white pr-4">Does it only generate customer-facing help docs, or can it do internal documentation too?</span>
          <svg data-role="icon" class="w-5 h-5 text-zinc-400 flex-shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div data-role="answer" class="overflow-hidden transition-all duration-200" style="max-height: 0px;">
          <p class="px-5 pb-5 text-zinc-400 leading-relaxed">
            Customer-facing help articles today. Internal documentation (runbooks, onboarding guides, architecture docs) is on our roadmap. Let us know if that's something you need.
          </p>
        </div>
      </div>

      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800" data-accordion-target="item">
        <button class="w-full flex items-center justify-between p-5 text-left" data-action="click->accordion#toggle">
          <span class="font-medium text-white pr-4">What if our team is sceptical about AI-generated content?</span>
          <svg data-role="icon" class="w-5 h-5 text-zinc-400 flex-shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div data-role="answer" class="overflow-hidden transition-all duration-200" style="max-height: 0px;">
          <p class="px-5 pb-5 text-zinc-400 leading-relaxed">
            Nothing publishes automatically. Every article lands in your inbox as a draft for human review and editing. Think of it as a first draft, not a finished product &mdash; your team stays in full control.
          </p>
        </div>
      </div>

      <div class="bg-zinc-900/50 backdrop-blur-sm rounded-xl border border-zinc-800" data-accordion-target="item">
        <button class="w-full flex items-center justify-between p-5 text-left" data-action="click->accordion#toggle">
          <span class="font-medium text-white pr-4">How long does it take to get set up?</span>
          <svg data-role="icon" class="w-5 h-5 text-zinc-400 flex-shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div data-role="answer" class="overflow-hidden transition-all duration-200" style="max-height: 0px;">
          <p class="px-5 pb-5 text-zinc-400 leading-relaxed">
            About 30 minutes. Connect your repo, point it at your help centre, and it analyses your codebase. After that, drafts are generated automatically every time a PR is merged.
          </p>
        </div>
      </div>

    </div>
  </div>

  <!-- CTA -->
  <div class="text-center" data-controller="analytics">
    <h2 class="text-2xl font-bold text-white mb-4" style="font-family: 'Space Grotesk', system-ui, sans-serif;">
      Ready to automate your docs?
    </h2>
    <p class="text-zinc-400 mb-8 max-w-lg mx-auto">
      Join the waitlist for early access, or sign in if you already have an invite.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <%= link_to login_path, class: "flex items-center justify-center gap-3 px-8 py-3.5 bg-white text-zinc-950 font-semibold rounded-xl hover:bg-zinc-100 transition-all duration-200 text-base", data: { action: "click->analytics#track", analytics_event: "cta_click", analytics_data: '{"cta":"github_signin_hiw"}' } do %>
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
        </svg>
        Sign in with GitHub
      <% end %>
      <a href="/#waitlist" class="px-8 py-3.5 bg-zinc-800 text-zinc-200 font-medium rounded-xl hover:bg-zinc-700 transition-all duration-200 text-base" data-action="click->analytics#track" data-analytics-event="cta_click" data-analytics-data='{"cta":"waitlist_hiw"}'>
        Join the waitlist
      </a>
    </div>
  </div>
</div>
